# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/neh
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/neh
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Polymarket APIs (no auth needed)
GAMMA_API_URL=https://gamma-api.polymarket.com
CLOB_API_URL=https://clob.polymarket.com
DATA_API_URL=https://data-api.polymarket.com

# Crawler
CRAWLER_REQUEST_DELAY_MS=50
CRAWLER_MAX_RETRIES=3
CRAWLER_PAGE_SIZE=100
SYNC_INTERVAL_MINUTES=5
ANALYTICS_REFRESH_MINUTES=15

# API
API_RATE_LIMIT_PER_MINUTE=100

# App
DEBUG=false
